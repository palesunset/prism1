PORT=3001

# --- Network hosting / security (recommended when not localhost-only) ---
#
# Generate a key: node scripts/generate-api-key.js
# When set, all /api routes (except /api/health) require:
#   Authorization: Bearer <API_KEY>   OR   X-API-Key: <API_KEY>
# API_KEY=

# Bind address. Default 127.0.0.1 (local only). Use 0.0.0.0 to listen on all interfaces.
# HOST=0.0.0.0

# Comma-separated browser origins allowed when using a separate Vite dev server.
# Example: CORS_ORIGINS=http://localhost:5173,http://192.168.1.50:5173
# CORS_ORIGINS=

# Set to 1 when behind nginx / a reverse proxy (for rate-limit client IP).
# TRUST_PROXY=1

# Rate limits (per IP, 15-minute window by default)
# RATE_LIMIT_MAX=300
# RATE_LIMIT_UPLOAD_MAX=20
# RATE_LIMIT_CHAT_MAX=30
# RATE_LIMIT_WINDOW_MS=900000

# Oz AI — local GGUF model (Inventory chat assistant)
#
# Default (if unset): backend/models/llama-3.2-3b-instruct-q4_k_m.gguf
# Use any compatible GGUF path — absolute or relative to the backend folder.
# Examples for different machine sizes:
#   OZ_MODEL_PATH=models/llama-3.2-3b-instruct-q4_k_m.gguf   # default ~2GB
#   OZ_MODEL_PATH=models/llama-3.2-1b-instruct-q4_k_m.gguf   # lighter ~1GB
#   OZ_MODEL_PATH=D:/AI/my-model.gguf                        # absolute path
# OZ_MODEL_PATH=

# Optional: Ollama (local LLM)
#
# Used by search routes (e.g. POST /api/ai-search, POST /api/equipment-count) when called directly.
#
# Defaults work for standard local Ollama:
# OLLAMA_URL=http://127.0.0.1:11434
#
# Use a tag from `ollama list`.
# Tiny models often fail strict JSON. If you have it pulled, `gemma2:2b` is usually more reliable.
# OLLAMA_MODEL=gemma2:2b
