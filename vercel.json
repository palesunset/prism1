{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm run install:vercel",
  "buildCommand": "npm run build:platform",
  "outputDirectory": "platform/frontend/dist",
  "functions": {
    "api/inventory.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/ipam.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/notes.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/lsp.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/lsp/:path*",
      "destination": "/api/lsp"
    },
    {
      "source": "/api/inventory/:path*",
      "destination": "/api/inventory"
    },
    {
      "source": "/api/ipam/:path*",
      "destination": "/api/ipam"
    },
    {
      "source": "/api/notes/:path*",
      "destination": "/api/notes"
    },
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
