{# Nokia SR OS — minimal transit: RSVP-TE on outward interface (all modes) #}
# LSP mode: {{ lsp_mode }} — transit on {{ ne_id }}
configure
    router "Base"
        rsvp
            interface "{{ outgoing_interface }}"
                no shutdown
            exit
        exit
    exit
exit
