{# Nokia SR OS — reverse (egress) RSVP-TE — legacy naming uses source_ne_id for path/LSP names #}
admin display-config | match {{ source_ne_id }} context all
show router mpls path {{ source_ne_id }}-SP:01 lsp-binding
show router mpls path {{ source_ne_id }}-SP:02 lsp-binding
show router mpls lsp {{ source_ne_id }}-SP:01
show router mpls lsp {{ source_ne_id }}-SP:02

/configure router mpls path {{ source_ne_id }}-SP:01
{% for hop in reverse_primary_hops %}
hop {{ loop.index }} {{ hop.ip }} strict
{% endfor %}
no shutdown
exit

{% if reverse_backup_hops %}
/configure router mpls path {{ source_ne_id }}-SP:02
{% for hop in reverse_backup_hops %}
hop {{ loop.index }} {{ hop.ip }} strict
{% endfor %}
no shutdown
exit

{% endif %}
/configure router mpls lsp {{ source_ne_id }}-SP:01
to {{ source_ip }}
path-computation-method local-cspf
fast-reroute facility
exit
egress-statistics
collect-stats
no shutdown
exit
primary {{ source_ne_id }}-SP:01 no shutdown
{% if reverse_backup_hops %}
secondary {{ source_ne_id }}-SP:02 no shutdown
secondary {{ source_ne_id }}-SP:02 standby
{% endif %}
no shutdown
exit

{% if reverse_backup_hops %}
/configure router mpls lsp {{ source_ne_id }}-SP:02
to {{ source_ip }}
cspf
fast-reroute facility
exit
egress-statistics
collect-stats
no shutdown
exit
primary {{ source_ne_id }}-SP:02 no shutdown
secondary {{ source_ne_id }}-SP:01 no shutdown
secondary {{ source_ne_id }}-SP:01 standby
no shutdown
exit

{% endif %}
/configure service sdp {{ reverse_sdp_number }} mpls create
far-end {{ source_ip }}
lsp {{ source_ne_id }}-SP:01
{% if reverse_backup_hops %}
lsp {{ source_ne_id }}-SP:02
{% endif %}
no shutdown
exit

{% if is_drrtr_pecrt_reverse %}
/configure service vprn 5000
spoke-sdp {{ reverse_sdp_number }}:5000 create
/admin save
{% endif %}
