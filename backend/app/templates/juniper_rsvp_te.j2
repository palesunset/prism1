{# Juniper Junos - RSVP (illustrative CLI) #}
{% if role == "ingress" %}
protocols {
    mpls {
        label-switched-path {{ lsp_name }} {
            to {{ dest_ip }};
            primary PRIMARY_PATH;
{% if backup_hops %}
            secondary BACKUP_PATH;
{% endif %}
        }
        path PRIMARY_PATH {
{% for hop in primary_hops %}
            {{ hop.next_hop_ip or "0.0.0.0" }} strict;
{% endfor %}
        }
{% if backup_hops %}
        path BACKUP_PATH {
{% for hop in backup_hops %}
            {{ hop.next_hop_ip or "0.0.0.0" }} strict;
{% endfor %}
        }
{% endif %}
    }
}
{% else %}
/* Juniper Junos {{ role }} node {{ ne_id }} for {{ lsp_name }} */
{% endif %}
