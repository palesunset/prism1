{# Huawei VRP — forward (ingress) RSVP-TE — explicit-path / tunnel names use source NE id (legacy) #}
sys
#
explicit-path {{ source_ne_id }}-LP:01
{% for hop in primary_hops %}
next hop {{ hop.ip }}
{% endfor %}
commit
quit
#
{% if backup_hops %}
explicit-path {{ source_ne_id }}-LP:02
{% for hop in backup_hops %}
next hop {{ hop.ip }}
{% endfor %}
commit
quit
#
{% endif %}
interface Tunnel0/0/{{ dest_tunnel_id }}
 description {{ dest_label }}
 ip address unnumbered interface LoopBack0
 tunnel-protocol mpls te
 destination {{ dest_ip }}
 mpls te record-route label
 mpls te backup hot-standby
 mpls te metric inherit-igp
 mpls te fast-reroute
 mpls te tunnel-id {{ dest_tunnel_id }}
 mpls te path explicit-path {{ source_ne_id }}-LP:01
{% if backup_hops %}
 mpls te path explicit-path {{ source_ne_id }}-LP:02 secondary
{% endif %}
#
{% if dest_vendor == "nokia" %}
mpls ldp remote-peer {{ dest_label }}
 remote-ip {{ dest_ip }}
{% endif %}
#
commit
quit
save
