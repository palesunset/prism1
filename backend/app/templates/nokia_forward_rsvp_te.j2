{# Nokia SR OS — forward (ingress) RSVP-TE — X=path prefix, Y/Z=LSP names #}
/configure router mpls path {{ nokia_path_name_prefix }}-SP:01
{% for hop in primary_hops %}
hop {{ loop.index }} {{ hop.ip }} strict
{% endfor %}
no shutdown
exit

{% if backup_hops %}
/configure router mpls path {{ nokia_path_name_prefix }}-SP:02
{% for hop in backup_hops %}
hop {{ loop.index }} {{ hop.ip }} strict
{% endfor %}
no shutdown
exit

{% if use_sp03 %}
/configure router mpls path {{ nokia_path_name_prefix }}-SP:03
{% for hop in primary_hops %}
hop {{ loop.index }} {{ hop.ip }} strict
{% endfor %}
no shutdown
exit

{% endif %}
{% endif %}
/configure router mpls lsp {{ nokia_lsp_name_y }}
to {{ dest_ip }}
path-computation-method local-cspf
fast-reroute facility
exit
egress-statistics
collect-stats
no shutdown
exit
primary {{ nokia_path_name_prefix }}-SP:01 no shutdown
{% if backup_hops %}
secondary {{ nokia_path_name_prefix }}-SP:02 standby
secondary dynamic
{% endif %}
no shutdown
exit

{% if backup_hops %}
/configure router mpls lsp {{ nokia_lsp_name_z }}
to {{ dest_ip }}
path-computation-method local-cspf
cspf
fast-reroute facility
exit
egress-statistics
collect-stats
no shutdown
exit
{% if use_sp03 %}
primary {{ nokia_path_name_prefix }}-SP:03 no shutdown
{% else %}
primary {{ nokia_path_name_prefix }}-SP:02 no shutdown
{% endif %}
{% if use_sp03 %}
secondary {{ nokia_path_name_prefix }}-SP:02 standby
{% else %}
secondary {{ nokia_path_name_prefix }}-SP:01 standby
{% endif %}
secondary dynamic
no shutdown
exit

{% endif %}
/configure service sdp {{ sdp_number }} mpls create
far-end {{ dest_ip }}
lsp {{ nokia_lsp_name_y }}
{% if backup_hops %}
lsp {{ nokia_lsp_name_z }}
{% endif %}
no shutdown
exit

{% if is_drrtr_pecrt %}
/configure service vprn 5000
spoke-sdp {{ sdp_number }}:5000 create
/admin save
{% endif %}

NOTE: Check the status of the new path. Expected status should be UP.
admin display-config | match {{ nokia_path_name_prefix }} context all
show router mpls path {{ nokia_path_name_prefix }}-SP:01 lsp-binding
{% if backup_hops %}
show router mpls path {{ nokia_path_name_prefix }}-SP:02 lsp-binding
{% endif %}
show router mpls lsp {{ nokia_lsp_name_y }}
{% if backup_hops %}
show router mpls lsp {{ nokia_lsp_name_z }}
{% endif %}
