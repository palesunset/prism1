{# Huawei VRP — reverse (egress) — legacy naming uses source_ne_id for explicit-path names #}
sys
#
explicit-path {{ source_ne_id }}-LP:01
{% for hop in reverse_primary_hops %}
next hop {{ hop.ip }}
{% endfor %}
commit
quit
#
{% if reverse_backup_hops %}
explicit-path {{ source_ne_id }}-LP:02
{% for hop in reverse_backup_hops %}
next hop {{ hop.ip }}
{% endfor %}
commit
quit
#
{% endif %}
interface Tunnel0/0/{{ source_tunnel_id }}
 description {{ source_label }}
 ip address unnumbered interface LoopBack0
 tunnel-protocol mpls te
 destination {{ source_ip }}
 mpls te record-route label
 mpls te backup hot-standby
 mpls te metric inherit-igp
 mpls te fast-reroute
 mpls te tunnel-id {{ source_tunnel_id }}
 mpls te path explicit-path {{ source_ne_id }}-LP:01
{% if reverse_backup_hops %}
 mpls te path explicit-path {{ source_ne_id }}-LP:02 secondary
{% endif %}
#
{% if source_vendor == "nokia" %}
mpls ldp remote-peer {{ source_label }}
 remote-ip {{ source_ip }}
{% endif %}
#
commit
quit
save
